<UserControl x:Class="TrajectoryLab.Desktop.Controls.ParameterField"
             x:Name="Root"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:TrajectoryLab.Desktop.Controls">
    <Grid Margin="0,3">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="170" />
            <ColumnDefinition Width="72" />
        </Grid.ColumnDefinitions>

        <controls:ParameterInfoLabel Label="{Binding Label, ElementName=Root}"
                                     HelpText="{Binding HelpText, ElementName=Root}" />

        <TextBox Grid.Column="1"
                 Margin="8,0"
                 Padding="5,3"
                 Text="{Binding Text, ElementName=Root, UpdateSourceTrigger=PropertyChanged}" />

        <TextBlock Grid.Column="2"
                   VerticalAlignment="Center"
                   Text="{Binding Unit, ElementName=Root}" />
    </Grid>
</UserControl>