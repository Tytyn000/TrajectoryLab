<UserControl x:Class="TrajectoryLab.Desktop.Controls.ParameterToggle"
             x:Name="Root"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:TrajectoryLab.Desktop.Controls">
    <Grid Margin="0,3">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="250" />
            <ColumnDefinition Width="72" />
        </Grid.ColumnDefinitions>

        <controls:ParameterInfoLabel Label="{Binding Label, ElementName=Root}"
                                     HelpText="{Binding HelpText, ElementName=Root}" />

        <CheckBox Grid.Column="1"
                  Margin="8,0"
                  VerticalAlignment="Center"
                  IsChecked="{Binding IsChecked, ElementName=Root, Mode=TwoWay}"
                  Content="Activé" />
    </Grid>
</UserControl>