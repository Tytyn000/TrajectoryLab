<UserControl x:Class="TrajectoryLab.Desktop.Controls.ParameterTextArea"
             x:Name="Root"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:TrajectoryLab.Desktop.Controls">
    <Grid Margin="0,6">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <controls:ParameterInfoLabel Label="{Binding Label, ElementName=Root}"
                                     HelpText="{Binding HelpText, ElementName=Root}" />

        <TextBox Grid.Row="1"
                 MinHeight="90"
                 Margin="0,6,0,0"
                 Padding="6"
                 AcceptsReturn="True"
                 AcceptsTab="False"
                 FontFamily="Consolas"
                 VerticalScrollBarVisibility="Auto"
                 Text="{Binding Text, ElementName=Root, UpdateSourceTrigger=PropertyChanged}" />
    </Grid>
</UserControl>